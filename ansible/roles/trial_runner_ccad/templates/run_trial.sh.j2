#!/bin/bash
# Rendered by ansible/roles/trial_runner_ccad — do not edit by hand.
# One SLURM array task = one trial of condition "{{ cond.key }}". Submitted via:
#   sbatch --array=1-{{ experiment_cfg.trials }} run_trial_{{ experiment_cfg.name }}_{{ cond.key }}.sh
#
# Replaces docker-compose (no equivalent under Singularity: no bridge
# networking/service-DNS, no depends_on/healthchecks) with 4 `singularity
# instance start` calls sharing this node's network namespace — hence
# HOST=localhost everywhere.
#
# CONFIRMED LIVE (2026-07-16): `--exclusive` (whole node per trial) was
# dropped early on after tripping AssocGrpCpuLimit with a modest account
# grant — but a later, much bigger 25-trial submission showed the account
# can in fact support many concurrent 6-CPU trials at once (short_qos's
# MaxTRESPU cpu=144 ÷ 6 = 24, matching exactly what was observed: 24
# trials RUNNING simultaneously, a 25th PENDING). With fixed ports
# (2551-2553, 5432) and fixed instance names (dl2l-manager, dl2l-db, ...),
# that many concurrent trials landing on the SAME node (confirmed live: up
# to 9 on one 56-CPU node) means real collisions, not just the sequential
# same-node-handoff race this file used to only guard against — different
# trials' JVMs could end up binding each other's ports or even
# cross-joining the same Akka cluster. Fixed at the root instead of
# fighting SLURM's scheduling: every port and every instance name below is
# derived from $SLURM_JOB_ID (globally unique per array task, unlike
# $SLURM_ARRAY_TASK_ID which repeats across different conditions' arrays),
# so concurrent trials on the same node simply don't share anything
# anymore. This also touches config/ccad-config.conf's seed-nodes entry,
# now parameterized via ${SEED_PORT} instead of hardcoded :2551.
#
# The trap below always writes a DONE sentinel (this task's exit code) and
# tears down only THIS trial's own instances (not --all — with concurrent
# trials sharing a node, --all would kill neighbors too), success or
# failure — mirrors roles/train_ccad/templates/train_variants.sh.j2's
# pattern. No live ansible/SSH connection is needed once submitted (the
# CEFET VPN drops on idle) — a separate `-e rescue=true` run checks for
# the DONE sentinel later.
#SBATCH --job-name=dl2l_{{ experiment_cfg.name }}_{{ cond.key }}
#SBATCH --partition={{ ccad_sim_partition }}
{% if ccad_sim_qos %}#SBATCH --qos={{ ccad_sim_qos }}
{% endif %}#SBATCH --nodes=1 --ntasks=1 --cpus-per-task={{ ccad_sim_cpus }}
#SBATCH --time={{ ccad_sim_time }}
#SBATCH --output={{ remote_work_dir }}/logs/{{ experiment_cfg.name }}_{{ cond.key }}_%A_%a.out
set -euo pipefail

TRIAL="${SLURM_ARRAY_TASK_ID:?must be run as a SLURM array task}"
TRIAL_DIR="{{ remote_work_dir }}/data/{{ experiment_cfg.name }}/{{ cond.key }}/trial_${TRIAL}"
mkdir -p "$TRIAL_DIR"

# Per-trial unique ports, derived from $SLURM_JOB_ID (see top-of-file note).
#
# CONFIRMED LIVE BUG (2026-07-16, first attempt at this fix): a stride of 1
# port per job id (`20000 + (SLURM_JOB_ID % 10000)`) is NOT enough — each
# trial needs a 7-port RANGE (postgres/manager/detector/holder + their 3
# metrics ports), but SLURM hands out numeric job ids to array tasks
# submitted together sequentially, so two ADJACENT trials' 7-port ranges
# overlapped massively (job N's port+1 == job N+1's port+0, etc.) — caught
# live as a holder crashing outright with `BindException: Address already
# in use` on a port that belonged to a DIFFERENT trial's manager. Fixed by
# spacing each trial's slot 20 ports apart (`* 20` below) instead of 1, so
# adjacent job ids can no longer overlap; modulus 2000 keeps the whole
# range (20000..60000) safely inside the valid unprivileged port space.
# Collisions between two *concurrently-running* trials now require job ids
# differing by an exact multiple of 2000 — not realistic at the ~24
# concurrent trials this account's CPU grant actually allows.
PORT_BASE=$((20000 + (SLURM_JOB_ID % 2000) * 20))
PG_PORT=$((PORT_BASE))
MANAGER_PORT=$((PORT_BASE + 1))
DETECTOR_PORT=$((PORT_BASE + 2))
HOLDER_PORT=$((PORT_BASE + 3))
METRICS_MANAGER_PORT=$((PORT_BASE + 4))
METRICS_DETECTOR_PORT=$((PORT_BASE + 5))
METRICS_HOLDER_PORT=$((PORT_BASE + 6))

DB_NAME="dl2l-db-${SLURM_JOB_ID}"
MANAGER_NAME="dl2l-manager-${SLURM_JOB_ID}"
DETECTOR_NAME="dl2l-detector-${SLURM_JOB_ID}"
HOLDER_NAME="dl2l-holder-${SLURM_JOB_ID}"

# Singularity writes per-instance logs (postgres/manager/detector/holder) to
# $HOME/.singularity/... — CCAD's NFS-mounted home, so every line written is
# network I/O, not local disk, and CONFIRMED LIVE one such log accumulated
# 240MB+ across a single session. TRIED pointing $HOME (and separately
# SINGULARITY_CONFIGDIR) at node-local scratch to keep that traffic off the
# network — CONFIRMED LIVE neither works cleanly: `$HOME` is ignored
# entirely for instance state (logs kept landing in the real, NFS-mounted
# home regardless), and `SINGULARITY_CONFIGDIR` redirects the logs
# correctly but leaves `instance list`/`instance stop` looking in a
# different, inconsistent location (both then report no instances found —
# this pipeline depends on `instance list`/`instance stop` throughout, so
# that's not a viable trade). Fixed at the actual source instead:
# config/ccad-config.conf's akka loglevel was DEBUG (copied verbatim from
# docker-config.conf, fine for local disk, not for NFS) — the gossip/
# heartbeat/serialization-warning spam that made these logs so large was
# happening at DEBUG specifically. Turned down to INFO there.
#
# CONFIRMED LIVE (full 25-trial run, 2026-07-15/16): a blind `instance stop
# --all` here is NOT sufficient proof this trial's ports are actually free
# by the time this function returns and the script exits — 19/25 trials
# failed that run, every single one starting with ZERO gap after the prior
# trial ended on the same node (SLURM schedules the next array task the
# instant a slot frees up). Now that every instance name is unique per
# trial (see top-of-file note), `--all` is also actively wrong under
# concurrency — it would tear down OTHER trials sharing this node. Stop
# only this trial's 4 named instances, and verify they're actually gone
# from `instance list` before letting the trap complete, instead of
# guessing at a fixed sleep.
cleanup() {
  local rc=$?
  echo "$rc" > "$TRIAL_DIR/DONE"
  singularity instance stop "$DB_NAME" "$MANAGER_NAME" "$DETECTOR_NAME" "$HOLDER_NAME" >/dev/null 2>&1 || true
  for _ in $(seq 1 20); do
    singularity instance list 2>/dev/null | grep -qE "^(${DB_NAME}|${MANAGER_NAME}|${DETECTOR_NAME}|${HOLDER_NAME}) " || break
    sleep 2
  done
  # CONFIRMED LIVE, expensively (2026-07-16): a Python 3.9-incompatibility
  # bug in dl2l_data/db.py crashed extraction on EVERY trial of a 25-trial
  # batch, right after each one had already run its full 60-minute
  # simulation successfully — and this trap's old unconditional `rm -rf`
  # below deleted every trial's postgres overlay (the only copy of that
  # hour of work) before the fix could be deployed. 24/25 trials'
  # data was unrecoverably lost. Postgres has just been cleanly stopped
  # above (consistent on-disk state, not a live snapshot), so copy its
  # overlay out to the NFS-backed $TRIAL_DIR before wiping node-local
  # /scratch — a one-time end-of-trial copy, not the live read/write
  # traffic during the run itself (which stays on node-local /scratch,
  # unchanged, per the earlier fix for that specific problem). If
  # extraction ever fails again, a fresh postgres instance can be started
  # against this saved overlay (`singularity instance start --overlay
  # <path> ... postgres_sandbox <name>`) and re-extracted by hand instead
  # of losing the trial outright.
  [ -f "${PG_OVERLAY:-}" ] && cp --sparse=always "$PG_OVERLAY" "$TRIAL_DIR/pg_overlay.img" 2>/dev/null
  rm -rf "/scratch/dl2l_${SLURM_JOB_ID:-unknown}"
}
trap cleanup EXIT

CONFIG_BIND="{{ remote_work_dir }}/config/ccad-config.conf:/config/docker-config.conf:ro"
INITDB_BIND="{{ remote_work_dir }}/config/init-db.sql:/docker-entrypoint-initdb.d/init-db.sql:ro"

# A Singularity SIF is read-only by default — --writable-tmpfs gives every
# instance an ephemeral, in-memory (tmpfs) writable overlay (discarded when
# the instance stops). Fine for the app containers (logs/tmp writes only)
# but CONFIRMED LIVE this is NOT enough for postgres: even a short trial's
# DDL bootstrap + WAL churn hit "PANIC: could not write to file
# pg_wal/xlogtemp.NN: No space left on device" — --writable-tmpfs has no
# size flag, and its default is evidently just a few tens of MB. postgres
# instead gets its own disk-backed (not RAM-backed) ext3 overlay image.
# The node-local copy is still ephemeral by design (mirrors how the
# local/Pi docker-compose postgres has no named volume either — extraction
# below copies everything needed out to the shared NFS before teardown),
# but the overlay ITSELF now survives the trial: cleanup()'s trap above
# copies it to $TRIAL_DIR (NFS) before deleting the node-local original,
# a recovery safety net (see that trap's own comment for why).
#
# CONFIRMED LIVE, twice:
# 1) A 1024 (1GB) overlay, sized only against a quick smoke write, filled up
#    after just ~12.5 minutes of a real 10-creature/40-minute trial. Once
#    full, EVERY subsequent postgres write failed with "No space left on
#    device" and the app retried in a tight loop — 700K+/500K+ duplicate
#    exception lines across holder/db logs in the remaining ~27 minutes.
#    That retry-loop spam, not verbose app logging, was the real source of
#    this session's multi-hundred-MB/GB log files. Bumped to 8192 (8GB) —
#    /scratch has 500GB+ free per node, so headroom is cheap; revisit if a
#    full-duration trial still exhausts this.
# 2) The overlay image lived at $TRIAL_DIR, under remote_work_dir — CCAD's
#    NFS-mounted $HOME — so every one of postgres's internal writes to it
#    (WAL, subtrans, every BDActor flush) was network I/O, same class of
#    problem as the singularity-instance-log issue above. Moved to
#    node-local /scratch (confirmed present and writable on every compute
#    node — a dedicated local disk mount, not NFS) instead; only the final
#    extracted parquet/pg_dump (far smaller, and only written once at the
#    end) still crosses the network into $TRIAL_DIR.
SCRATCH_DIR="/scratch/dl2l_${SLURM_JOB_ID}"
mkdir -p "$SCRATCH_DIR"
WRITABLE="--writable-tmpfs"
PG_OVERLAY="$SCRATCH_DIR/pg_overlay.img"
singularity overlay create --size 8192 "$PG_OVERLAY"

# --- postgres --------------------------------------------------------------
# Runs from a pre-built sandbox directory (roles/image_ccad), not `docker://`
# — confirmed live that compute nodes have no internet access, so any
# `docker://` reference would fail here. No --fakeroot: CCAD support mapped
# this account's uid on compute nodes (see docs/plans/ccad-singularity-experiments.md),
# so the official postgres image's entrypoint runs fine as our real,
# resolvable uid — no user-namespace trickery needed. PGPORT: the official
# postgres image's entrypoint reads this to listen on a non-default port,
# needed so concurrent trials on the same node don't all fight over :5432.
singularity instance start --overlay "$PG_OVERLAY" \
  --bind "$INITDB_BIND" \
  --env POSTGRES_PASSWORD=postgres --env POSTGRES_DB=l2l --env PGPORT="$PG_PORT" \
  {{ remote_work_dir }}/postgres_sandbox "$DB_NAME"

echo "Waiting for postgres..."
pg_ready=0
for _ in $(seq 1 60); do
  singularity exec "instance://${DB_NAME}" pg_isready -U postgres -p "$PG_PORT" >/dev/null 2>&1 && { pg_ready=1; break; }
  sleep 2
done
# CONFIRMED LIVE GAP (found via a smoke-test failure where the dl2l app's own
# entrypoint was silently broken): the original loops here had no failure
# check, so a service that never comes up is indistinguishable from one that
# started instantly — the script just sails on to extraction, which then
# fails opaquely ("No creatures found") instead of pointing at the real
# problem. Every wait loop below now fails fast with the instance's own log.
[ "$pg_ready" = 1 ] || { echo "FATAL: postgres never became ready"; singularity instance list; exit 1; }

# Each trial's manager log is now uniquely named (dl2l-manager-<jobid>.err —
# see MANAGER_NAME above), so unlike before there's no shared/appended file
# across trials to worry about skipping past — every match here is
# guaranteed to belong to THIS trial alone. (ls under `if` is not subject to
# `set -e` — if-conditions are one of the contexts it exempts — so no `|| true`
# dance is needed here the way earlier bare `VAR=$(...)` assignments needed one.)
find_manager_log() {
  ls $HOME/.singularity/instances/logs/*/*/"${MANAGER_NAME}.err" 2>/dev/null | head -1
}

# --- manager (+ idProvider) --------------------------------------------------
# SEED_PORT: config/ccad-config.conf's akka.cluster.seed-nodes now reads
# ${SEED_PORT} instead of a hardcoded :2551, so detector/holder can find
# this trial's own manager regardless of which port it landed on.
# METRICS_PORT: every role's JVM starts a MetricsExtension /metrics endpoint
# unconditionally (see Main.java) — needs its own per-trial port for the
# same reason as the app ports.
singularity instance start $WRITABLE \
  --bind "$CONFIG_BIND" \
  --env ROLE=manager,idProvider --env SIMULATION={{ cond.simulation }} \
  --env HOST=localhost --env PORT="$MANAGER_PORT" --env SEED_PORT="$MANAGER_PORT" \
  --env METRICS_PORT="$METRICS_MANAGER_PORT" \
  --env DL2L_DB_URL="jdbc:postgresql://localhost:${PG_PORT}/l2l" \
  {{ remote_work_dir }}/dl2l_sandbox "$MANAGER_NAME"

echo "Waiting for manager..."
mgr_ready=0
for _ in $(seq 1 60); do
  (exec 3<>/dev/tcp/localhost/$MANAGER_PORT) 2>/dev/null && { exec 3<&- 3>&-; mgr_ready=1; break; }
  sleep 2
done
[ "$mgr_ready" = 1 ] || { echo "FATAL: manager never came up on :$MANAGER_PORT"; singularity instance list; exit 1; }

# --- collisionDetector -------------------------------------------------------
singularity instance start $WRITABLE \
  --bind "$CONFIG_BIND" \
  --env ROLE=collisionDetector --env SIMULATION={{ cond.simulation }} \
  --env HOST=localhost --env PORT="$DETECTOR_PORT" --env SEED_PORT="$MANAGER_PORT" \
  --env METRICS_PORT="$METRICS_DETECTOR_PORT" \
  {{ remote_work_dir }}/dl2l_sandbox "$DETECTOR_NAME"

# --- holder -------------------------------------------------------------------
singularity instance start $WRITABLE \
  --bind "$CONFIG_BIND" \
  --env ROLE=holder --env SIMULATION={{ cond.simulation }} \
  --env HOST=localhost --env PORT="$HOLDER_PORT" --env SEED_PORT="$MANAGER_PORT" \
  --env METRICS_PORT="$METRICS_HOLDER_PORT" \
  --env DL2L_DB_URL="jdbc:postgresql://localhost:${PG_PORT}/l2l" \
  {{ remote_work_dir }}/dl2l_sandbox "$HOLDER_NAME"

# A holder that crashes on startup disappears from `instance list` almost
# immediately — indistinguishable from "already finished" to the loop below
# unless we first confirm it actually came up.
#
# CONFIRMED LIVE (2026-07-16): a single fixed `sleep 3` here false-positived
# under heavy concurrency (9 trials x 4 instances = 36 concurrent
# `singularity instance start` calls contending for one node) — the
# diagnostic `instance list` dump this FATAL prints on failure showed the
# holder instance WAS actually there, just not yet visible 3s in. Retrying
# for up to 15s total fixes this without meaningfully slowing down the
# common case (holder usually shows up within the first second or two).
holder_up=0
for _ in $(seq 1 15); do
  singularity instance list 2>/dev/null | grep -q "^${HOLDER_NAME} " && { holder_up=1; break; }
  sleep 1
done
[ "$holder_up" = 1 ] \
  || { echo "FATAL: holder never came up"; singularity instance list; exit 1; }

# CONFIRMED LIVE BUG: the instance being up is not the same as the simulation
# actually having started. Job 200 (2026-07-15): holder joined the Akka
# cluster fine (its own "Welcome from [manager]" logged) and MLServiceExtension
# loaded fine, but it never sent its application-level Register message to
# manager — manager's log shows zero "Registering a new holder"/"Starting all
# creatures" for the entire run. Since completion detection below only checks
# for manager's COMPLETION messages, not that the run ever started, the
# forced-timeout path still fires regardless — the trial "succeeds" from
# run_trial.sh's point of view while extraction finds zero creatures. Fail
# fast instead of burning the full in-sim deadline on a silently-empty
# trial: give the registration handshake a couple of minutes, watching
# manager's log for the same "Starting all creatures" signal
# startSimulation() logs once every holder has ack'd ready.
echo "Waiting for the simulation to actually start (holder registration)..."
sim_started=0
for _ in $(seq 1 24); do
  if MANAGER_LOG=$(find_manager_log) && [ -n "$MANAGER_LOG" ] \
      && grep -q "Starting all creatures" "$MANAGER_LOG" 2>/dev/null; then
    sim_started=1
    break
  fi
  sleep 5
done
if [ "$sim_started" != 1 ]; then
  echo "FATAL: simulation never started — holder came up but never registered with manager within 2 minutes"
  MANAGER_LOG=$(find_manager_log) || true
  [ -n "${MANAGER_LOG:-}" ] && tail -80 "$MANAGER_LOG"
  exit 1
fi

# CONFIRMED LIVE BUG: polling `singularity instance list` for the holder to
# disappear is NOT reliable completion detection — under a real (non-smoke)
# 25-trial run, 6 trials were cut short after ~35-175s instead of running
# toward the in-sim deadline, with ZERO natural creature deaths logged (no
# "Sending remove order to holder" messages) and the holder's own log
# showing "Starting coordinated shutdown from JVM shutdown hook" — proof
# the JVM was killed by an EXTERNAL signal, not a natural game-over. The
# likely culprit: `instance list` has some transient hiccup under load from
# 4 concurrently-running instances, `grep` finds no match on that one poll,
# the loop breaks, and this script's own EXIT trap then kills the
# STILL-RUNNING simulation itself.
#
# TRIED watching the holder's own log for Holder.java's handleFinish()
# message ("Received stop order from manager. Stopping") next — CONFIRMED
# LIVE this message (and its natural-death sibling, "This holder has
# finished his work.") never appears in EITHER the holder's .out or .err,
# even on a validation run that demonstrably reached "Maximum runtime
# reached" on the manager side. Holder.java's logger field uses plain
# java.util.logging (`Logger.getLogger(...)`), unlike the akka/SLF4J-based
# logging everything else here goes through — it appears to have no
# configured handler in this JVM and its output goes nowhere capturable.
#
# manager's own logger DOES work reliably (confirmed live: "Simulation
# runtime limited to N minutes" and "Maximum runtime reached — stopping
# simulation" both showed up exactly as expected) — SimulationManager logs
# "All creatures dead in holder <id>" for the natural-death path and
# "Maximum runtime reached — stopping simulation" for the forced-timeout
# path, both from the same onReceive handler, both BEFORE stopSimulation()
# sends Finish to every holder/idProvider/collisionDetector — so watching
# manager's log for either one is a strictly earlier and, unlike holder's,
# actually-visible completion signal.
#
# TRIED adding a `singularity instance list` short-circuit on top (3
# consecutive missing-holder polls, ~15s of confirmed absence, treated as a
# real crash) so a genuinely-dead holder wouldn't have to wait out the full
# ceiling below — CONFIRMED LIVE this is STILL a false positive even with
# that debounce: a run using this exact 3-strikes logic was killed by its
# own EXIT trap at ~90s in while the holder's own log shows it was actively
# processing right up to the same second the trap tore everything down (no
# exception, no OOM, no "shutting down" of its own). Given that a
# false-positive kill silently produces truncated, scientifically-invalid
# data while a false-negative (a genuinely-dead holder just sitting until
# the ceiling below) only costs wall-clock time on an async
# submit-and-rescue job, dropped the `instance list` check entirely —
# completion detection now rests solely on manager's log, backstopped by
# the ceiling below and, ultimately, SBATCH --time.
#
# SimulationManager also exposes a `dl2l_simulation_running` gauge (0/1)
# over its own /metrics endpoint (docs/plans/ccad-metrics-completion-detection.md)
# — a direct, synchronous query against live process state, with none of
# the log-grep path's dependency on Singularity flushing the instance log
# to NFS in a timely way. Checked FIRST every poll; the log-grep is kept as
# a fallback (CONFIRMED LIVE the manager's HTTP server tears down within
# about a second of stopSimulation(), so an external 5s-interval poller
# essentially never observes the 0 reading in practice — the log-grep
# fallback is what actually fires almost every time, and that's fine, this
# is deliberately opportunistic not load-bearing).
echo "Waiting for the simulation to finish..."
sim_done=0
# ~90 min ceiling: generous margin beyond the in-sim maxRuntimeMinutes cap
# (currently 60 minutes across simulations/20260714_memory_vs_wm_dense_reposition_*.conf).
# CONFIRMED LIVE a tighter 50-min ceiling raced against a simulation that
# legitimately ran its full 40-minute in-sim deadline plus real-world JVM/
# processing overhead (jobs completed at 41-47 min wall-clock for a 40-min
# cap) — keep a similar ~25-30 min margin over whatever the cap is. SBATCH
# --time is the ultimate backstop regardless.
for _ in $(seq 1 1080); do
  if curl -s -m 3 "http://localhost:${METRICS_MANAGER_PORT}/metrics" 2>/dev/null \
      | grep -qE '^dl2l_simulation_running\{[^}]*\} 0(\.0)?$'; then
    echo "Completion detected via /metrics (dl2l_simulation_running=0)"
    sim_done=1
    break
  fi
  if MANAGER_LOG=$(find_manager_log) && [ -n "$MANAGER_LOG" ] \
      && grep -qE "All creatures dead in holder|Maximum runtime reached" "$MANAGER_LOG" 2>/dev/null; then
    echo "Completion detected via manager log fallback"
    sim_done=1
    break
  fi
  sleep 5
done
if [ "$sim_done" != 1 ]; then
  echo "FATAL: simulation did not finish within the wait timeout"
  MANAGER_LOG=$(find_manager_log) || true
  [ -n "${MANAGER_LOG:-}" ] && tail -80 "$MANAGER_LOG"
  exit 1
fi

# manager logging "Maximum runtime reached"/"All creatures dead" only means
# stopSimulation() has been TOLD to run, not that the holder has actually
# finished flushing/exiting yet (its own Finish handling and JVM teardown
# take a few more seconds) — give it a moment before extracting.
sleep 10

# --- extract (before teardown; dl2l_data.extract does its own pg_dump backup) -
# The system python3 has no pandas/pyarrow (needed for --format parquet) —
# CONFIRMED LIVE this crashed extraction outright even after a trial
# actually completed successfully. TRIED `module load miniforge3 && conda
# activate` here (a dedicated dl2l-extract env, provisioned once by
# provision-ccad.yml) — CONFIRMED LIVE this breaks the singularity exec
# subprocess dl2l_data.db shells out to for psql (almost certainly
# LD_LIBRARY_PATH contamination from the conda module, inherited by that
# subprocess): postgres was demonstrably still running (a trial had already
# succeeded moments earlier without this activation) but psql suddenly
# couldn't find its own unix socket. Fixed by installing pandas/pyarrow into
# the system python3's --user site-packages instead (provision-ccad.yml) —
# no environment activation, so nothing here can leak into the singularity
# subprocess call.
PYTHONPATH="{{ remote_work_dir }}/scripts" python3 -m dl2l_data.extract \
  --experiment "{{ experiment_cfg.name }}" \
  --condition "{{ cond.key }}" \
  --trial "$TRIAL" \
  --out "{{ remote_work_dir }}/data/{{ experiment_cfg.name }}" \
  --container "$DB_NAME" --runtime singularity --db-port "$PG_PORT" \
  --format {{ experiment_cfg.extract.format }}{% if not experiment_cfg.extract.backup %} \
  --skip-backup{% endif %}
