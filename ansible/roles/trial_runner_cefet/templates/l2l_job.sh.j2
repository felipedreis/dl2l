#!/bin/bash
# {{ ansible_managed | default("Rendered by ansible/roles/trial_runner_cefet — do not edit by hand.") }}
#
# Modernized scripts/l2l_job.sh: same per-role sbatch job body (one job per
# Akka cluster role — manager, idProvider, collisionDetector, holder), but
# qos/partition are parameterized from ansible/inventories/cefet/group_vars.
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=12
#SBATCH --qos={{ cefet_qos }}
#SBATCH --partition={{ cefet_partition }}

module load jdk8

config=$1
role=$2
LD="-Djava.library.path=../natives"
save_dir=${SLURM_JOB_ID}

if [ "$role" = "holder" ]; then
    mkdir -p ${save_dir}/data ${save_dir}/backup
fi

# DL2L_DB_URL is exported here as a forward-compatibility hook for the
# postgres seam (see roles/trial_runner_cefet/tasks/db_setup.yml) — nothing
# on the Java side reads it yet. src/main/resources/META-INF/persistence.xml
# still hardcodes jdbc:postgresql://dl2l-db:5432/l2l with no override
# mechanism; wiring DL2L_DB_URL through there is part of the follow-up task
# that resolves the seam, not this one.
export DL2L_DB_URL="${DL2L_DB_URL:-jdbc:postgresql://REPLACE_ME:5432/l2l}"

java -jar ${LD} l2l.jar --host `hostname -I` --port 2550 --roles ${role} --simulation ${config} --save "${save_dir}/data"

# PROVISIONAL — ported verbatim from the legacy script, which assumed a
# postgres reachable at localhost with a `felipe` role/password. That
# assumption is exactly what the db_setup.yml seam blocks on: there is
# currently no resolved postgres story for CEFET, so this pg_dump will not
# work as-is. Kept here as a record of the historical behavior a future
# implementer needs to replace, not as working logic.
if [ "$role" = "holder" ]; then
    pg_dump -d "l2l" -U felipe -W --role=felipe -f ${save_dir}/backup/`hostname`.backup -F c <<< "123456"
fi
