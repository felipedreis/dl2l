#!/bin/bash
# {{ ansible_managed | default("Rendered by ansible/roles/trial_runner_cefet — do not edit by hand.") }}
#
# Submits the full "{{ experiment_cfg.name }}" experiment as chains of SLURM
# jobs, one chain per (condition, trial). Ported from the legacy
# scripts/deploy.sh, which took (config, runs) as CLI args and looped
# internally — this rendered version bakes in this experiment's specific
# conditions/trials at template time instead, since the script is
# regenerated fresh per experiment run by ansible.
#
# Kept as a single monolithic script (rather than porting the loop into
# ansible tasks the way trial_runner_pi loops over conditions and calls
# `sbatch` directly for its SLURM array submission) because each TRIAL here
# is not one SLURM array task but a *chain* of separate per-role jobs
# (manager, idProvider, collisionDetector, holder x N) tied together with
# --dependency=afterany:, and successive trials within a condition are
# themselves chained onto the previous trial's job IDs so they run strictly
# one after another. Modeling that job-ID threading in ansible facts/loops
# would be materially more complex than in bash for no real benefit — and
# this whole role is blocked on the postgres seam anyway (db_setup.yml fails
# before this script is ever rendered or run), so it isn't worth the
# abstraction until CEFET is actually back in active use.
set -euo pipefail

cd "{{ remote_work_dir }}"

{% for cond in experiment_cfg.conditions %}
echo "=== condition: {{ cond.key }} ({{ experiment_cfg.trials }} trials) ==="
CONFIG="config/{{ cond.simulation | basename }}"
HOLDERS=$(grep holders "$CONFIG" | sed -e 's/[^0-9]//g')
DEPENDENCY=""

for TRIAL in $(seq 1 {{ experiment_cfg.trials }}); do
    MANAGER=$(sbatch $DEPENDENCY --job-name="manager" -w {{ cefet_manager_node }} l2l_job.sh "$CONFIG" "manager" | grep -o "[0-9]*")
    PROVIDER=$(sbatch $DEPENDENCY --job-name="idProvider" l2l_job.sh "$CONFIG" "idProvider" | grep -o "[0-9]*")
    DETECTOR=$(sbatch $DEPENDENCY --job-name="collisionDetector" l2l_job.sh "$CONFIG" "collisionDetector" | grep -o "[0-9]*")
    IDS="${MANAGER}:${PROVIDER}:${DETECTOR}"

    sleep 10

    for I in $(seq 1 "$HOLDERS"); do
        HOLDER_ID=$(sbatch $DEPENDENCY --job-name="holder-${I}" l2l_job.sh "$CONFIG" "holder" | grep -o "[0-9]*")
        IDS+=":${HOLDER_ID}"
    done

    echo "  trial ${TRIAL}: submitted ${IDS}"
    DEPENDENCY="--dependency=afterany:${IDS}"
done
{% endfor %}

echo "All conditions submitted for {{ experiment_cfg.name }}. Monitor with: squeue -u \$USER"
