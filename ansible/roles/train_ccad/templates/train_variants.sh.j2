#!/bin/bash
# Rendered by ansible/roles/train_ccad — do not edit by hand.
# Trains, collapse-checks, and exports every requested variant sequentially
# inside one SLURM allocation on CCAD's gpu partition, entirely autonomously
# (no live ansible/SSH connection needed once submitted — the CEFET VPN
# drops on idle, so nothing can hang around waiting for this to finish).
# Aborts (set -e) on the first failure — matches roles/train_local's "hard
# gate" behaviour: already-exported earlier variants keep their files.
#
# The trap below always writes a DONE sentinel (this job's exit code) under
# $HOME (shared NFS) on exit, success or failure — that's what the later
# `-e rescue=true` run checks for. NOTE: this trap does not fire if the job
# is killed outright (OOM-killed, walltime exceeded, node failure) — in that
# case check `squeue`/`sacct` or this file's own slurm-%j.out log manually.
#SBATCH --job-name=jepa_{{ training_cfg.name }}
#SBATCH --partition={{ ccad_partition }}
#SBATCH --qos={{ ccad_qos }}
#SBATCH --gres={{ ccad_gres }}
#SBATCH --output={{ remote_train_dir }}/slurm-%j.out
set -euo pipefail

trap 'echo "$?" > "{{ remote_train_dir }}/DONE"' EXIT

{{ ccad_python_activate }}

cd "{{ remote_train_dir }}/ml"
mkdir -p ../checkpoints ../models

VARIANTS=({{ training_cfg.variants | join(' ') }})
TRAIN_FLAGS=(--epochs {{ training_cfg.epochs }}{% if 'batch' in training_cfg.hyperparams %} --batch {{ training_cfg.hyperparams.batch }}{% endif %}{% if 'lr' in training_cfg.hyperparams %} --lr {{ training_cfg.hyperparams.lr }}{% endif %}{% if 'sigreg' in training_cfg.hyperparams %} --sigreg {{ training_cfg.hyperparams.sigreg }}{% endif %}{% if 'crit' in training_cfg.hyperparams %} --crit {{ training_cfg.hyperparams.crit }}{% endif %}{% if 'ema' in training_cfg.hyperparams %} --ema {{ training_cfg.hyperparams.ema }}{% endif %}{% if training_cfg.hyperparams.freeze_encoder | default(false) %} --freeze-encoder{% endif %})
DEVICE_FLAG=(--device {{ training_cfg.device | default('cuda') }})

for VARIANT in "${VARIANTS[@]}"; do
  echo "=== [$VARIANT] train_species ==="
  python3 -m scripts.train_species --data ../data_prepared --ckpt "../checkpoints/$VARIANT" --variant "$VARIANT" "${TRAIN_FLAGS[@]}" "${DEVICE_FLAG[@]}"

  echo "=== [$VARIANT] check_collapse ==="
  python3 -m scripts.check_collapse --ckpt "../checkpoints/$VARIANT" --data ../data_prepared --variant "$VARIANT" "${DEVICE_FLAG[@]}"

  echo "=== [$VARIANT] export_model ==="
  python3 -m scripts.export_model --ckpt "../checkpoints/$VARIANT" --out "../models/$VARIANT" --variant "$VARIANT" "${DEVICE_FLAG[@]}"
done
