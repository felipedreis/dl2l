#!/bin/bash
# Rendered by ansible/roles/image_ccad — do not edit by hand.
# Pulls {{ item.ref }} as a Singularity SIF and builds a writable sandbox
# from it, once, on the login node (which has internet and full account
# resolution — compute nodes have neither, confirmed live).
#
# Run detached (setsid nohup, launched by tasks/main.yml) so it survives a
# VPN drop mid-build — CONFIRMED LIVE a plain synchronous ansible task here
# died outright on a drop, and ansible's async+poll mechanism (tried as a
# fix) hung indefinitely reporting stale status even after the remote job
# had genuinely finished. The calling task polls for this script's own
# "done" marker instead, via `until`/`retries` — each retry opens a fresh
# SSH connection, so a drop just delays the next check instead of failing
# the whole run.
set -euo pipefail

SIF="{{ remote_work_dir }}/{{ item.sif }}"
SANDBOX="{{ remote_work_dir }}/{{ item.name }}_sandbox"
MARKER="{{ remote_work_dir }}/.{{ item.name }}_image_build.done"
LOG="{{ remote_work_dir }}/.{{ item.name }}_image_build.log"

rm -f "$MARKER"
{
  singularity pull --force "$SIF" "docker://{{ item.ref }}"
  rm -rf "$SANDBOX"
  singularity build --sandbox --force "$SANDBOX" "$SIF"

  # CONFIRMED LIVE BUG: `singularity instance start` runs a sandbox's
  # `.singularity.d/startscript`, not `.singularity.d/runscript` — but SIFs
  # converted from a `docker://` image only ever get a populated
  # `runscript` (translating the image's ENTRYPOINT/CMD; used by
  # `singularity run`/bare `exec`). Their `startscript` is an empty no-op,
  # so `instance start` on an unmodified sandbox launches an idle instance
  # that never runs postgres (or the dl2l app) at all — confirmed live:
  # `instance start` reported "started successfully" and `pg_isready`
  # looped forever with no server ever up, and both the instance's own
  # .out/.err logs were empty.
  cp "$SANDBOX/.singularity.d/runscript" "$SANDBOX/.singularity.d/startscript"

{% if item.name == "dl2l" %}
  # CONFIRMED LIVE BUG: dl2l's ENTRYPOINT is `./run-dl2l.sh ...` (a
  # relative path — see docker/Dockerfile's WORKDIR /dl2l/run), which
  # Docker resolves via WORKDIR automatically. `instance start` does not
  # apply the image's WORKDIR the same way (confirmed live:
  # "./run-dl2l.sh: not found"), and unlike `exec`/`run`, `instance start`
  # has no `--pwd` flag to set it per-invocation either (confirmed live:
  # "unknown flag: --pwd"). Fixed at the source instead: inject `cd
  # /dl2l/run` as the first line of the startscript, which every code path
  # in the generated script runs through.
  sed -i '1a cd /dl2l/run' "$SANDBOX/.singularity.d/startscript"
{% endif %}

  echo done > "$MARKER"
} > "$LOG" 2>&1
