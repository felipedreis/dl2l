# Add any directories, files, or patterns you don't want to be tracked by version control
*.class
target/
*.iml
*.jar
.idea
*.aux
*.log
*.pyc
.DS_Store
__pycache__/

# Track experiment data, raw simulation CSVs, and checkpoints for reproducibility.
# Exclude only compiled model weights that are regenerated by the pipeline.
!data/
!ml/data/
!ml/checkpoints/
# Ignore large intermediate parquet files — regenerated by prepare_dataset.py
ml/data_*/
# Ignore raw Java/IDE project files
.classpath
.project
.settings/
.claude/
