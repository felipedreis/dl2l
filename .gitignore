# Add any directories, files, or patterns you don't want to be tracked by version control
*.class
target/
*.iml
*.jar
.idea
*.aux
*.log
*.pyc
.DS_Store
__pycache__/

# Training data, experiment outputs, and model checkpoints live on HuggingFace,
# not in git. Only the small deployed TorchScript models (src/main/resources/models/)
# stay in the repo since they are needed to build the JAR.
data/
ml/data/
ml/checkpoints/
# Ansible per-run scratch state (rendered docker-compose.yml, etc.)
ansible/.run/

# Local secrets/PII — never commit (e.g. CCAD_USERNAME, a CPF)
.env.local
.env.*.local
.env

# Ignore raw Java/IDE project files
.classpath
.project
.settings/
.claude/
